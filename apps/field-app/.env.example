# Uradi Monitor - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================
# REQUIRED - Application
# =============================================

# Environment: development | staging | production
EXPO_PUBLIC_ENV=development

# Brand: uradi360 (public) or campaign ID
EXPO_PUBLIC_BRAND_ID=uradi360

# Backend API
EXPO_PUBLIC_API_URL=https://api.uradi360.org
EXPO_PUBLIC_API_VERSION=v1

# =============================================
# REQUIRED - Blockchain (Polygon)
# =============================================

# RPC endpoint - use Mumbai for dev, Mainnet for production
EXPO_PUBLIC_POLYGON_RPC=https://rpc-mumbai.maticvigil.com

# Smart contract address for evidence anchoring
EXPO_PUBLIC_CONTRACT_ADDRESS=0x...

# IPFS gateway for retrieving anchored content
EXPO_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs

# =============================================
# OPTIONAL - Monitoring & Analytics
# =============================================

# Sentry error tracking (production recommended)
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Firebase (for analytics, campaign distribution)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# =============================================
# OPTIONAL - Maps
# =============================================

# Mapbox for polling unit maps
EXPO_PUBLIC_MAPBOX_TOKEN=pk.ey...

# =============================================
# OPTIONAL - EAS Build (CI/CD)
# =============================================

# EAS project ID
EXPO_PUBLIC_EAS_PROJECT_ID=

# App Store Connect (iOS deployment)
EXPO_PUBLIC_IOS_APP_ID=
EXPO_PUBLIC_ASC_ISSUER_ID=
EXPO_PUBLIC_ASC_KEY_ID=

# =============================================
# DEVELOPMENT ONLY
# =============================================

# Enable detailed logging
EXPO_PUBLIC_DEBUG_MODE=true

# Skip blockchain anchoring (dev only)
EXPO_PUBLIC_MOCK_BLOCKCHAIN=false

# Mock GPS location (dev only)
EXPO_PUBLIC_MOCK_GPS=false
