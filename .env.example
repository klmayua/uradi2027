# URADI-360 Production Environment Configuration
# ============================================
# SECURITY: These are placeholder values. Replace before deployment.
# DO NOT commit this file with real values!
# ============================================

# ============================================
# AI/LLM SERVICES - KIMI
# Get from: https://platform.moonshot.ai/
# ============================================
KIMI_API_KEY=sk-YOUR_KIMI_API_KEY_HERE
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2-turbo-preview

# ============================================
# SMS SERVICES - TERMII
# Get from: https://termii.com/
# ============================================
TERMII_API_KEY=YOUR_TERMII_API_KEY_HERE
TERMII_SENDER_ID=URADI360
TERMII_BASE_URL=https://api.termii.com/api/

# ============================================
# WHATSAPP - TWILIO
# Get from: https://console.twilio.com/
# ============================================
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE_NUMBER
TWILIO_WHATSAPP_NUMBER=YOUR_TWILIO_WHATSAPP_NUMBER

# ============================================
# EMAIL - SENDGRID
# Get from: https://sendgrid.com/
# ============================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@uradi360.com
SENDGRID_FROM_NAME=URADI-360

# ============================================
# PAYMENTS - PAYSTACK
# Get from: https://dashboard.paystack.com/
# ============================================
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=whsec_your_webhook_secret
PAYSTACK_BASE_URL=https://api.paystack.co

# ============================================
# AUTHENTICATION - GOOGLE
# Get from: https://console.cloud.google.com/
# ============================================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ============================================
# FIREBASE
# Get from: https://console.firebase.google.com/
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_SERVICE_ACCOUNT=your-firebase-service-account-json

# ============================================
# DATABASE (CONFIGURE FOR PRODUCTION)
# Provider: Railway, Supabase, or AWS RDS
# ============================================
DATABASE_URL=postgresql://uradi:DB_PASSWORD@localhost:5432/uradi360
DATABASE_URL_LOCAL=postgresql://uradi:DB_PASSWORD@localhost:5436/uradi
POSTGRES_USER=uradi
POSTGRES_PASSWORD=GENERATE_NEW_PASSWORD
POSTGRES_DB=uradi360
DB_PORT=5432
DB_HOST=localhost
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ============================================
# REDIS (CONFIGURE FOR PRODUCTION)
# Provider: Railway, Upstash, or Redis Cloud
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_URL_LOCAL=redis://localhost:6380
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PASSWORD=

# ============================================
# MINIO OBJECT STORAGE
# Or use AWS S3, Google Cloud Storage
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=GENERATE_NEW_ACCESS_KEY
MINIO_SECRET_KEY=GENERATE_NEW_SECRET_KEY
MINIO_CONSOLE_PORT=9001

# ============================================
# SECURITY - AUTO-GENERATED SECRETS
# Generate with: openssl rand -hex 64
# Rotate these immediately after first deployment
# ============================================
JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_REFRESH_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_64
SESSION_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7
BCRYPT_ROUNDS=12

# ============================================
# MISSING - NEED SETUP
# ============================================
MAPBOX_TOKEN=your_mapbox_token_here
SENTRY_DSN=your_sentry_dsn_here
AFRICASTALKING_API_KEY=your_africastalking_key_here
AFRICASTALKING_USERNAME=your_africastalking_username

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=production
FRONTEND_PORT=4321
BACKEND_PORT=8000
FRONTEND_URL=https://uradi360.vercel.app
BACKEND_URL=https://uradi360-backend.up.railway.app

# Feature Flags
ENABLE_USSD=true
ENABLE_WHATSAPP=true
ENABLE_SMS=true
ENABLE_EMAIL=true
ENABLE_PAYMENTS=true

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_WINDOW_MS=60000

# CORS - Update with your actual domains
CORS_ORIGIN=https://uradi360.vercel.app,https://uradi360.com
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false

# Super Admin (Change before deployment)
SUPERADMIN_EMAIL=admin@uradi360.com
